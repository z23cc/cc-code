{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh",
            "timeout": 5
          }
        ],
        "description": "Show skills overview + recent project context at session start"
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/prompt-context.sh",
            "timeout": 3
          }
        ],
        "description": "Auto-inject task/epic context when IDs detected in message"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/worktree-guard.sh",
            "timeout": 3
          }
        ],
        "description": "Worktree boundary guard: block edits outside assigned worktree (when CC_WORKTREE_PATH is set)",
        "statusMessage": "Checking worktree boundary..."
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/config-protect.sh",
            "timeout": 3
          }
        ],
        "description": "Warn when modifying linter/formatter/CI config files"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-commit-gate.sh",
            "timeout": 5
          }
        ],
        "description": "Quality gate: remind to verify before git commit",
        "statusMessage": "Checking commit quality..."
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-push-review.sh",
            "timeout": 5
          }
        ],
        "description": "Review reminder before git push with diff stats"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-task-hint.sh",
            "timeout": 5
          }
        ],
        "description": "After cc-flow done/scan, suggest next steps",
        "statusMessage": "Checking workflow hints..."
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-verify.sh",
            "timeout": 3
          }
        ],
        "description": "Remind to verify after editing source code files"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact.sh",
            "timeout": 10
          }
        ],
        "description": "Auto-save session state before context compaction",
        "statusMessage": "Saving session before compaction..."
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-end.sh",
            "timeout": 10
          }
        ],
        "description": "Auto-save session and consolidate learnings at session end"
      }
    ]
  }
}
