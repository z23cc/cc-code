{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "cat ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.md 2>/dev/null || true"
          }
        ],
        "description": "Inject cc-code skills overview at session start"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-commit-gate.sh",
            "timeout": 5
          }
        ],
        "description": "Quality gate: remind to verify before git commit",
        "statusMessage": "Checking commit quality..."
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-task-hint.sh",
            "timeout": 5
          }
        ],
        "description": "After cc-flow done/scan, suggest next steps",
        "statusMessage": "Checking workflow hints..."
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact.sh",
            "timeout": 10
          }
        ],
        "description": "Auto-save session state before context compaction",
        "statusMessage": "Saving session before compaction..."
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-end.sh",
            "timeout": 10
          }
        ],
        "description": "Auto-save session and consolidate learnings at session end"
      }
    ]
  }
}
