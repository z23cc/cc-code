{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh",
            "timeout": 5
          }
        ],
        "description": "Show skills overview + dashboard auto-start + recent context"
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/prompt-context.sh",
            "timeout": 3
          }
        ],
        "description": "Auto-inject task/epic context when IDs detected in message"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/worktree-guard.sh",
            "timeout": 3
          }
        ],
        "description": "Block edits outside assigned worktree"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/config-protect.sh",
            "timeout": 3
          }
        ],
        "description": "Block modifications to linter/formatter/CI configs (exit 2)"
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/mode-guard.sh",
            "timeout": 3
          }
        ],
        "description": "Safety modes: careful/freeze/guard"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-commit-gate.sh",
            "timeout": 5
          }
        ],
        "description": "Quality gate: require cc-flow verify before git commit"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-push-review.sh",
            "timeout": 5
          }
        ],
        "description": "Review reminder before git push"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-task-hint.sh",
            "timeout": 5
          }
        ],
        "description": "After cc-flow commands, suggest next steps"
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-verify.sh",
            "timeout": 3
          }
        ],
        "description": "Remind to verify after editing source code"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/failure-counter.sh",
            "timeout": 3
          }
        ],
        "description": "Track consecutive Bash failures for methodology switching"
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/subagent-complete.sh",
            "timeout": 5
          }
        ],
        "description": "Track subagent completion, emit dashboard event"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact.sh",
            "timeout": 10
          }
        ],
        "description": "Auto-save session state before compaction"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-end.sh",
            "timeout": 10
          }
        ],
        "description": "Auto-save session and consolidate learnings"
      }
    ]
  }
}
