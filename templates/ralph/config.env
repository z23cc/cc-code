# cc-code Ralph — Autonomous Execution Configuration
# Copy to scripts/ralph/config.env and customize

# Review backends: agent | rp | codex | none
PLAN_REVIEW=agent
WORK_REVIEW=agent
COMPLETION_REVIEW=agent
REQUIRE_PLAN_REVIEW=0

# Loop controls
MAX_ITERATIONS=25
MAX_ATTEMPTS_PER_TASK=5
MAX_REVIEW_ITERATIONS=3
WORKER_TIMEOUT=3600

# Branch strategy: worktree (default, max isolation) | new | current
BRANCH_MODE=worktree

# Execution
YOLO=1
EPICS=

# Watch mode colors
RALPH_UI=1

# ── Goal-Driven Mode ──
# When GOAL is set, Ralph runs continuously until the goal is achieved.
# It will: generate tasks if none exist, self-heal on failures, and verify completion.
# GOAL="" means normal mode (work through existing tasks then stop).
GOAL=""

# Goal verification: how Ralph checks if the goal is met
# "tests" = all tests pass, "health" = cc-flow health >= threshold, "custom" = run GOAL_VERIFY_CMD
GOAL_VERIFY="tests"
GOAL_HEALTH_THRESHOLD=80
GOAL_VERIFY_CMD=""

# Self-healing: when stuck, Ralph can create new tasks to unblock itself
SELF_HEAL=1
SELF_HEAL_SCAN_INTERVAL=5  # run deep scan every N iterations to find new issues
